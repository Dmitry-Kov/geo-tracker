# Скопируй в .env и впиши ключи. Движки включаются автоматически по наличию ключа.

# Бесплатно: https://aistudio.google.com -> Get API key (карта не нужна)
GEMINI_API_KEY=

# Кредиты Pro-подписки или pay-as-you-go: https://www.perplexity.ai/settings/api
PERPLEXITY_API_KEY=

# Платно (копейки на mini): https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Опционально — переопределить модели:
# GEMINI_MODEL=gemini-flash-latest
# PERPLEXITY_MODEL=sonar
# OPENAI_MODEL=gpt-5-mini
