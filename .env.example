# Copy to .env and fill in your keys. Engines enable themselves when a key is present.

# Free: https://aistudio.google.com -> Get API key (no credit card)
GEMINI_API_KEY=

# Pro subscription credits or pay-as-you-go: https://www.perplexity.ai/settings/api
PERPLEXITY_API_KEY=

# Paid (cents on mini): https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Optional — override the models:
# GEMINI_MODEL=gemini-flash-latest
# PERPLEXITY_MODEL=sonar
# OPENAI_MODEL=gpt-5-mini
